    "languageModelTools": [
      {
        "name": "cosmosdb_sampleContainerSchema",
        "displayName": "Sample Container Schema",
        "modelDescription": "Samples a few documents from the active Cosmos DB container to infer its schema (property names and types). Runs a cheap, read-only query. Use this when the container schema is unknown, to avoid guessing property names or casing. If the schema is already available (e.g. containerSchema from cosmosdb_getQueryEditorContext), you do not need to call this.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "cosmosdb_sampleContainerSchema"
      },
      {
        "name": "cosmosdb_getQueryEditorContext",
        "displayName": "Get Query Editor Context",
        "modelDescription": "Returns the context of the active Cosmos DB Query Editor: the full editor text (currentQuery, which may contain multiple queries), the selected query if any (selectedQuery), the single query to operate on or explain (activeQuery — the selection when present, otherwise the full text), the persisted container schema (if one has already been sampled or inferred), recent query history, and result metadata (row counts, request charge, inferred result schema). Never returns raw document data. Use this to ground query generation or explanation; if it returns a containerSchema, you already know the schema and do not need to sample again.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "cosmosdb_getQueryEditorContext"
      },
      {
        "name": "cosmosdb_applyQueryToEditor",
        "displayName": "Apply Query to Editor",
        "modelDescription": "Writes a generated Cosmos DB NoSQL query into the active Query Editor, replacing its contents. The previous query is preserved below the new one as a commented \"Previous query\" block. Pass the user's original natural-language request as promptDescription so it is cited in a \"Generated from\" comment. Applying does NOT run the query; if the user wants to see results, call cosmosdb_executeCurrentQuery afterwards.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "cosmosdb_applyQueryToEditor",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "The generated Cosmos DB NoSQL query to write into the active Query Editor."
            },
            "promptDescription": {
              "type": "string",
              "description": "The user's original natural-language request, cited in the \"Generated from\" comment above the query."
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "cosmosdb_executeCurrentQuery",
        "displayName": "Execute Current Query",
        "modelDescription": "Runs the CURRENT query in the active Cosmos DB Query Editor (the selected text if there is a selection, otherwise the full editor content) and shows the results in the editor grid. Use this whenever the user wants to see, show, list, find, count, or return data — writing or applying a query does NOT run it. This tool takes no query parameter; it always runs whatever is currently in the editor, so to run a specific or newly generated query you MUST first call cosmosdb_applyQueryToEditor to make it the current query, then call this tool. Asks the user for confirmation first because it reads data and consumes Request Units (RUs). Returns only PII-free result metadata (row count, request charge, inferred result schema) — never raw documents.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "cosmosdb_executeCurrentQuery"
      }
    ],
    "chatParticipants": [
      {
        "id": "cosmosdb",
        "name": "cosmosdb",
        "fullName": "Cosmos DB (NoSQL) Assistant",
        "description": "AI-powered assistant for Azure Cosmos DB (NoSQL) help, best practices, and code examples",
        "disambiguation": [
          {
            "category": "databases",
            "description": "The user wants help with their NoSQL Cosmos DB database",
            "examples": [
              "Optimize my query to improve performance and cost",
              "Explain my current query",
              "Help me write a NoSQL query"
            ]
          }
        ],
        "isSticky": true,
        "commands": [
          {
            "name": "editQuery",
            "description": "Edit query with LLM suggestions and user confirmation"
          },
          {
            "name": "help",
            "description": "Show available commands and help"
          },
          {
            "name": "explainQuery",
            "description": "Explain the current query with AI analysis"
          },
          {
            "name": "generateQuery",
            "description": "Generate a new query from natural language description"
          },
