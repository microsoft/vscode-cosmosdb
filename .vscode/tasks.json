{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build (tsc -watch)",
      "type": "shell",
      "command": "pnpm run compile",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": "$tsc-watch"
    },
    {
      "label": "Pretest",
      "type": "shell",
      "command": "pnpm run pretest",
      "group": "build",
      "isBackground": true,
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": "$tsc-watch"
    },
    {
      "label": "Lint",
      "type": "shell",
      "command": "pnpm run lint",
      "problemMatcher": "$eslint-stylish"
    },

    // ── Vite watch (default F5 workflow) ────────────────────────────────────────
    {
      "label": "Watch",
      "dependsOn": ["vite-watch:ext", "vite-watch:views"]
    },
    {
      "label": "vite-watch:ext",
      "type": "shell",
      "command": "pnpm run vite-watch:ext",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new",
        "showReuseMessage": false,
        "clear": true,
        "group": "Cosmos DB Extension Watch"
      }
    },
    {
      "label": "vite-watch:views",
      "type": "shell",
      "command": "pnpm run vite-watch:views",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new",
        "showReuseMessage": false,
        "clear": true,
        "group": "Cosmos DB Extension Watch"
      }
    },

    // ── Webpack watch (kept as alternative) ─────────────────────────────────────
    {
      "label": "Watch (webpack)",
      "dependsOn": ["watch:ext", "watch:views"]
    },
    {
      "label": "watch:ext",
      "type": "shell",
      "command": "pnpm run watch:ext",
      "group": "build",
      "isBackground": true,
      "problemMatcher": ["$ts-webpack-watch", "$tslint-webpack-watch"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new",
        "showReuseMessage": false,
        "clear": true,
        "group": "Cosmos DB Extension Watch (webpack)"
      }
    },
    {
      "label": "watch:views",
      "type": "shell",
      "command": "pnpm run watch:views",
      "group": "build",
      "isBackground": true,
      "problemMatcher": ["$ts-webpack-watch", "$tslint-webpack-watch"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new",
        "showReuseMessage": false,
        "clear": true,
        "group": "Cosmos DB Extension Watch (webpack)"
      }
    },

    {
      "label": "Pretest and Watch",
      "dependsOn": ["Pretest", "Watch"]
    },
    {
      "label": "Pretest and Webpack",
      "dependsOn": ["Pretest", "Watch (webpack)"]
    },
    {
      "label": "CosmosDB Emulator",
      "type": "shell",
      "command": "docker-compose up; docker-compose down",
      "windows": {
        "command": "try { docker-compose up } finally { docker-compose down }"
      },
      "group": "none",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "close": false
      },
      "problemMatcher": []
    }
  ]
}
