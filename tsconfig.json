{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "out",
    "rootDir": ".",
    "types": ["mocha", "node"],
    "typeRoots": ["node_modules/@types"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.json", "main.ts"],
  "exclude": ["node_modules", ".vscode-test", "out", "dist", "test", "src/**/*.test.ts", "**/__mocks__"]
}
