{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "promise"],
  "jsPlugins": ["eslint-plugin-license-header"],
  "categories": {
    "suspicious": "warn",
    "perf": "warn"
  },

  "env": {
    "builtin": true,
    "es2023": true,
    "node": true
  },
  "ignorePatterns": [
    ".azure-pipelines",
    ".config",
    ".github",
    ".vscode-test",
    "coverage",
    "dist",
    "out",
    "node_modules",
    "**/__mocks__/**/*",
    "**/*.d.ts",
    "**/jest.config.js",
    "**/main.js"
  ],
  "rules": {
    // These are NOT default-on in correctness, so we enable them explicitly:
    "no-empty": "error",
    "no-inner-declarations": "error",
    // Default correctness rule but with custom options:
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    // Style rules we opt into:
    "eqeqeq": ["error", "always"],
    // Plugin rules:
    "import/consistent-type-specifier-style": ["error", "prefer-inline"],
    // License header (jsPlugin):
    "license-header/header": [
      "error",
      [
        "/*---------------------------------------------------------------------------------------------",
        " *  Copyright (c) Microsoft Corporation. All rights reserved.",
        " *  Licensed under the MIT License. See License.txt in the project root for license information.",
        " *--------------------------------------------------------------------------------------------*/"
      ]
    ]
  },
  "overrides": [
    {
      "files": ["**/*.ts"],
      "plugins": ["typescript"],
      "rules": {
        // Disable JS rules that TypeScript handles natively (default-on correctness rules):
        "constructor-super": "off",
        "no-class-assign": "off",
        "no-const-assign": "off",
        "no-dupe-class-members": "off",
        "no-dupe-keys": "off",
        "no-func-assign": "off",
        "no-import-assign": "off",
        "no-new-native-nonconstructor": "off",
        "no-obj-calls": "off",
        "no-redeclare": "off",
        "no-setter-return": "off",
        "no-this-before-super": "off",
        "no-unsafe-negation": "off",
        "no-with": "off",
        // Style rules (not default, need explicit opt-in):
        "no-var": "error",
        "prefer-const": "error",
        "prefer-rest-params": "error",
        "prefer-spread": "error",
        "no-array-constructor": "error",
        // Default correctness with custom options:
        "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
        // TypeScript-specific rules that are NOT default-on
        // (default-on ones: no-duplicate-enum-values, no-misused-new, no-this-alias,
        //  no-wrapper-object-types, prefer-as-const, triple-slash-reference,
        //  no-extra-non-null-assertion, no-non-null-asserted-optional-chain,
        //  no-unsafe-declaration-merging, prefer-namespace-keyword — all auto-enabled by plugin):
        "typescript/ban-ts-comment": "error",
        "typescript/no-empty-object-type": "error",
        "typescript/no-explicit-any": "error",
        "typescript/no-require-imports": "error",
        "typescript/consistent-type-imports": "error",
        "typescript/no-restricted-types": "error",
        "typescript/no-unnecessary-type-constraint": "error",
        "typescript/no-unsafe-function-type": "error",
        // TypeScript defaults we want disabled:
        "typescript/no-namespace": "off",
        "typescript/no-inferrable-types": "off"
      }
    },
    {
      "files": ["**/*.tsx"],
      "plugins": ["typescript", "react", "jsx-a11y", "react-perf"],
      "env": {
        "browser": true
      },
      "rules": {
        // Disable JS rules that TypeScript handles natively:
        "constructor-super": "off",
        "no-class-assign": "off",
        "no-const-assign": "off",
        "no-dupe-class-members": "off",
        "no-dupe-keys": "off",
        "no-func-assign": "off",
        "no-import-assign": "off",
        "no-new-native-nonconstructor": "off",
        "no-obj-calls": "off",
        "no-redeclare": "off",
        "no-setter-return": "off",
        "no-this-before-super": "off",
        "no-unsafe-negation": "off",
        "no-with": "off",
        // Style rules:
        "no-var": "error",
        "prefer-const": "error",
        "prefer-rest-params": "error",
        "prefer-spread": "error",
        "no-array-constructor": "error",
        "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
        // TypeScript non-default rules:
        "typescript/ban-ts-comment": "error",
        "typescript/no-empty-object-type": "error",
        "typescript/no-explicit-any": "error",
        "typescript/no-require-imports": "error",
        "typescript/consistent-type-imports": "error",
        "typescript/no-restricted-types": "error",
        "typescript/no-unnecessary-type-constraint": "error",
        "typescript/no-unsafe-function-type": "error",
        // TypeScript defaults we want disabled:
        "typescript/no-namespace": "off",
        "typescript/no-inferrable-types": "off",
        // React defaults we want disabled:
        "react/no-unsafe": "off",
        "react/react-in-jsx-scope": "off",
        // jsx-a11y adjustments:
        "jsx-a11y/anchor-ambiguous-text": "off",
        "jsx-a11y/no-noninteractive-tabindex": [
          "error",
          {
            "tags": [],
            "roles": ["tabpanel"],
            "allowExpressionValues": true
          }
        ],
        "jsx-a11y/no-static-element-interactions": [
          "error",
          {
            "allowExpressionValues": true,
            "handlers": ["onClick", "onMouseDown", "onMouseUp", "onKeyPress", "onKeyDown", "onKeyUp"]
          }
        ],
        // react-perf (warn, not error):
        "react/exhaustive-deps": "warn",
        "react/no-array-index-key": "warn",
        "jsx-no-jsx-as-prop": "warn",
        "jsx-no-new-function-as-prop": "warn",
        "jsx-no-new-object-as-prop": "warn",
        "jsx-no-new-array-as-prop": "warn"
      }
    },
    {
      "files": ["src/**/*.test.ts", "**/__mocks__/**/*.js"],
      "plugins": ["typescript", "jest"],
      "env": {
        "jest": true
      },
      "rules": {
        // Style rules:
        "no-array-constructor": "error",
        "no-unused-vars": "error",
        // TypeScript non-default rules (some relaxed for tests):
        "typescript/ban-ts-comment": "error",
        "typescript/no-empty-object-type": "error",
        "typescript/no-explicit-any": "off",
        "typescript/no-require-imports": "error",
        "typescript/no-unnecessary-type-constraint": "error",
        "typescript/no-unsafe-function-type": "error",
        "typescript/no-non-null-assertion": "off",
        // Jest rules: override level (off/warn) — "error" ones auto-enabled by plugin+correctness:
        "jest/expect-expect": "off",
        "jest/no-alias-methods": "error",
        "jest/no-commented-out-tests": "warn",
        "jest/no-conditional-expect": "off",
        "jest/no-deprecated-functions": "error",
        "jest/no-disabled-tests": "warn",
        "jest/no-done-callback": "error",
        "jest/no-export": "error",
        "jest/no-focused-tests": "error",
        "jest/no-identical-title": "error",
        "jest/no-interpolation-in-snapshots": "error",
        "jest/no-jasmine-globals": "error",
        "jest/no-mocks-import": "error",
        "jest/no-standalone-expect": "error",
        "jest/no-test-prefixes": "error",
        "jest/valid-describe-callback": "error",
        "jest/valid-expect": "error",
        "jest/valid-expect-in-promise": "error",
        "jest/valid-title": "error",
        // Disable specific correctness rules for test files:
        "no-dupe-else-if": "off",
        "no-empty": "off",
        "no-empty-function": "off"
      }
    },
    {
      "files": ["test/**/*.ts", "test/**/*.test.ts"],
      "plugins": ["typescript"],
      "jsPlugins": ["eslint-plugin-mocha"],
      "env": {
        "mocha": true
      },
      "rules": {
        // Style rules:
        "no-array-constructor": "error",
        "no-unused-vars": "error",
        // TypeScript non-default rules (relaxed for tests):
        "typescript/ban-ts-comment": "error",
        "typescript/no-empty-object-type": "error",
        "typescript/no-explicit-any": "off",
        "typescript/no-require-imports": "error",
        "typescript/no-unnecessary-type-constraint": "error",
        "typescript/no-unsafe-function-type": "error",
        "typescript/no-non-null-assertion": "off",
        // Mocha rules:
        "mocha/handle-done-callback": "off",
        "mocha/max-top-level-suites": "off",
        "mocha/no-async-suite": "error",
        "mocha/no-exclusive-tests": "warn",
        "mocha/no-exports": "error",
        "mocha/no-global-tests": "error",
        "mocha/no-hooks": "off",
        "mocha/no-hooks-for-single-case": "off",
        "mocha/no-identical-title": "error",
        "mocha/no-mocha-arrows": "off",
        "mocha/no-nested-tests": "error",
        "mocha/no-pending-tests": "warn",
        "mocha/no-return-and-callback": "error",
        "mocha/no-return-from-async": "off",
        "mocha/no-setup-in-describe": "error",
        "mocha/no-sibling-hooks": "error",
        "mocha/no-synchronous-tests": "off",
        "mocha/no-top-level-hooks": "warn",
        "mocha/prefer-arrow-callback": "off",
        "mocha/valid-suite-title": "off",
        "mocha/valid-test-title": "off",
        "mocha/no-empty-title": "error",
        "mocha/consistent-spacing-between-blocks": "off",
        // Disable specific correctness rules for test files:
        "no-dupe-else-if": "off",
        "no-empty": "off",
        "no-restricted-imports": "off",
        "no-empty-function": "off"
      }
    }
  ]
}
