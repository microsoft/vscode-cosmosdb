{
  "compilerOptions": {
    // Strictness
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "noUnusedParameters": true,

    // Module: standalone ESM library (no bundler)
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2024",
    "lib": ["ES2024"],

    // Other
    "sourceMap": true,
    "resolveJsonModule": true,

    // Output
    "outDir": "dist/esm",
    "rootDir": "src",
    "declaration": true,
    "declarationDir": "dist/types",
    "declarationMap": true,
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "tests", "**/*.test.ts"]
}
