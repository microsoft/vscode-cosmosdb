# Use hoisted node_modules layout for compatibility with:
# - vsce (VS Code Extension packaging tool)
# - webpack loaders that expect flat node_modules
# - ts-loader, css-loader, etc.
node-linker=hoisted

# Automatically install peer dependencies
auto-install-peers=true

# Do not fail on missing peer dependencies (some @microsoft/vscode-azext-* packages have loose peers)
strict-peer-dependencies=false

