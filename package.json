  "scripts": {
    "build": "concurrently -n tsc,vitest,test -c cyan,magenta,yellow \"tsc --noEmit\" \"tsc -p tsconfig.vitest.json --noEmit\" \"tsc -p tsconfig.test.json --noEmit\"",
    "build:go": "concurrently -n tsgo,vitest,test -c cyan,magenta,yellow \"tsgo --noEmit\" \"tsgo -p tsconfig.vitest.json --noEmit\" \"tsgo -p tsconfig.test.json --noEmit\"",
    "clean": "git clean -dfx",
    "compile": "tsc -watch",
    "package": "node scripts/package-vsix.mjs",
    "lint": "concurrently -n oxlint,eslint -c blue,green \"oxlint --quiet\" \"eslint --quiet .\"",
    "lint-fix": "concurrently -n oxlint,eslint -c blue,green \"oxlint --fix\" \"eslint --fix .\"",
    "prettier": "oxfmt --check",
    "prettier-fix": "oxfmt",
    "pretest": "rimraf out && tsc -p tsconfig.test.json && node -e \"require('fs').writeFileSync('out/package.json', JSON.stringify({type:'module'}))\"",
    "test": "node scripts/run-integration-tests.mjs",
    "vitest": "vitest run",
    "vitest:coverage": "vitest run --coverage",
    "vitest:ui": "vitest --ui",
    "vite-dev": "rimraf ./dist && concurrently -n ext,views -c redBright,whiteBright \"npm run vite-dev-ext\" \"npm run vite-dev-wv\"",
    "vite-prod": "rimraf ./dist && concurrently -n ext,views -c redBright,whiteBright \"npm run vite-prod-ext\" \"npm run vite-prod-wv\"",
    "vite-dev-ext": "vite build --mode development --config ./vite.config.ext.mjs",
    "vite-dev-wv": "vite build --mode development --config ./vite.config.views.mjs",
    "vite-prod-ext": "vite build --mode production --config ./vite.config.ext.mjs",
    "vite-prod-wv": "vite build --mode production --config ./vite.config.views.mjs",
    "vite-watch:ext": "vite build --mode development --watch --config ./vite.config.ext.mjs",
    "vite-watch:views": "vite build --mode development --watch --config ./vite.config.views.mjs",
    "vite-serve:views": "vite --mode development --config ./vite.config.views.mjs",
    "resapi.resetall": "rimraf out node_modules dist && npm install && npm run resapi.link",
    "resapi.link": "npm link @microsoft/vscode-azureresources-api",
    "l10n": "node l10n/scripts/build.l10n.mjs",
    "l10n:check": "node l10n/scripts/check.l10n.mjs",
    "l10n:auto": "cross-env AZURE_TRANSLATOR_KEY= cross-env AZURE_TRANSLATOR_REGION= npx @vscode/l10n-dev generate-azure --outDir ./l10n ./l10n/bundle.l10n.json ./package.nls.json",
    "l10n:export": "npx @vscode/l10n-dev generate-xlf ./l10n/bundle.l10n.json --outFile vscode-cosmosdb.xlf",
    "l10n:import": "npx @vscode/l10n-dev import-xlf ./translations.xlf",
    "fetch-skill": "node scripts/fetch-skill.mjs",
    "pre-commit": "npm run build && npm run prettier-fix && npm run lint-fix && npm run l10n && npm run vitest",
    "docker-up": "docker compose up -d",
    "docker-down": "docker compose down",
    "docker-restart": "npm run docker-down && npm run docker-up",
    "e2e": "playwright test",
    "e2e:coverage": "cross-env COSMOSDB_E2E_COVERAGE=1 playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:emulator:up": "docker compose -f docker-compose.e2e.yml -p cosmosdb-e2e up -d --remove-orphans",
    "e2e:emulator:down": "docker compose -f docker-compose.e2e.yml -p cosmosdb-e2e down --volumes --remove-orphans",
    "e2e:emulator:seed": "node scripts/import-seed.mjs --all --reset --endpoint https://localhost:8082 --database nosql-test-db"
  },
  "externalSkills": {
    "cosmosdb-best-practices": {
