{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["mocha", "node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "main.ts",
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/tests/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "out", "**/__mocks__"]
}
