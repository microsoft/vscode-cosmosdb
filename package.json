        "command": "cosmosDB.e2e.openMigrationFresh",
        "title": "[E2E Test] Open Empty Migration Assistant"
      }
    ],
    "submenus": [
      {
        "id": "azureDatabases.submenus.workspaceActions",
        "label": "Azure Cosmos DB",
        "icon": {
          "dark": "resources/azurecosmosdb.png",
          "light": "resources/azurecosmosdb.png"
        }
      }
    ],
    "menus": {
      "azureDatabases.submenus.workspaceActions": [
        {
          "command": "cosmosDB.newConnection",
          "group": "1_newConnection@1"
        }
      ],
      "view/title": [
        {
          "submenu": "azureDatabases.submenus.workspaceActions",
          "when": "view == azureWorkspace",
          "group": "navigation@6"
        }
      ],
      "editor/context": [
        {
          "command": "azureDatabases.update",
          "when": "resourceFilename=~/(.*cosmos-document[.]json)/"
        },
        {
          "command": "azureDatabases.update",
          "when": "resourceFilename=~/(.*cosmos-stored-procedure[.]js)/"
        },
        {
          "command": "cosmosDB.importDocument",
          "when": "resourceLangId==json"
        }
      ],
      "editor/title": [
        {
          "command": "azureDatabases.update",
          "when": "resourceFilename=~/(.*cosmos-document[.]json)(?![a-z])/i",
          "group": "navigation"
        },
        {
          "command": "azureDatabases.update",
          "when": "resourceFilename=~/(.*cosmos-stored-procedure[.]js)(?![a-z])/i",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "azureDatabases.createServer",
          "when": "view == azureResourceGroups && viewItem =~ /(AzureCosmosDb)/i && viewItem =~ /azureResourceTypeGroup/i",
          "group": "1@1"
        },
        {
          "//": "[Account] Open Account Overview - Azure Resources accounts only (ARM metadata required)",
          "command": "cosmosDB.openAccountOverview",
          "when": "view =~ /azure(ResourceGroups|FocusView)/ && viewItem =~ /hasarmmetadata/i",
          "group": "1@1"
        },
        {
          "//": "[Account] Create account database",
          "command": "cosmosDB.createDatabase",
          "when": "view =~ /azure(ResourceGroups|FocusView|Workspace)/ && viewItem =~ /treeitem[.]account(?![a-z.\\/])/i",
          "group": "1@2"
        },
        {
          "//": "[Account] Delete account",
          "command": "cosmosDB.deleteAccount",
          "when": "view =~ /azure(ResourceGroups|FocusView)/ && viewItem =~ /treeitem[.]account(?![a-z.\\/])/i",
          "group": "1@3"
        },
        {
          "//": "[Account] Detach account (workspace only)",
          "command": "cosmosDB.removeConnection",
          "when": "view =~ /azureWorkspace/ && viewItem =~ /treeitem[.]account(?![a-z.\\/])/i",
          "group": "1@3"
        },
        {
          "//": "[Account] CosmosDB Filter tree items",
          "command": "azureDatabases.filterTreeItems",
          "when": "view =~ /azure(ResourceGroups|FocusView|Workspace)|vscode-fabric.view/ && viewItem =~ /treeitem[.](filterable)(?![a-z.\\/])/i",
          "group": "inline"
        },
        {
          "//": "[Account] CosmosDB Sort tree items",
          "command": "azureDatabases.sortTreeItems",
          "when": "view =~ /azure(ResourceGroups|FocusView|Workspace)|vscode-fabric.view/ && viewItem =~ /treeitem[.](sortable)(?![a-z.\\/])/i",
          "group": "inline"
        },
        {
          "//": "[Account] CosmosDB Copy connection string",
          "command": "cosmosDB.copyConnectionString",
          "when": "view =~ /azure(ResourceGroups|FocusView|Workspace)|vscode-fabric.view/ && viewItem =~ /treeitem[.]account(?![a-z.\\/])/i",
          "group": "2@1"
        },
        {
          "//": "[Account] Refresh (workspace only)",
          "command": "azureDatabases.refresh",
          "when": "view =~ /azureWorkspace/ && viewItem =~ /treeitem[.]account(?![a-z.\\/])/i",
          "group": "3@1"
        },
        {
          "//": "[Database] Create NoSql container",
          "command": "cosmosDB.createContainer",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)|vscode-fabric.view/ && viewItem =~ /treeitem[.]database(?![a-z.\\/])/i && viewItem =~ /experience[.](core|fabric)/i",
          "group": "1@1"
        },
        {
          "//": "[Database] Delete database",
          "command": "cosmosDB.deleteDatabase",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)/ && viewItem =~ /treeitem[.]database(?![a-z.\\/])/i && viewItem =~ /experience[.](core)/i",
          "group": "1@2"
        },
        {
          "//": "[Database] View NoSql database offer",
          "command": "cosmosDB.viewDatabaseOffer",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)/ && viewItem =~ /treeitem[.]database(?![a-z.\\/])/i && viewItem =~ /experience[.](core)/i",
          "group": "1@3"
        },
        {
          "//": "[Database] Launch Cosmos DB Shell",
          "command": "cosmosDB.launchCosmosDBShell",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)/ && (viewItem =~ /treeitem[.]database(?![a-z.\\/])/i || viewItem =~ /treeitem[.]container(?![a-z.\\/])/i) && viewItem =~ /experience[.]core/i",
          "group": "1@4"
        },
        {
          "//": "[Database] Refresh",
          "command": "azureDatabases.refresh",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)/ && viewItem =~ /treeitem[.]database(?![a-z.\\/])/i",
          "group": "3@1"
        },
        {
          "//": "[Container] Open NoSql query editor",
          "command": "cosmosDB.openNoSqlQueryEditor",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)|vscode-fabric.view/ && viewItem =~ /treeitem[.]container(?![a-z.\\/])/i && viewItem =~ /experience[.](core|fabric)/i",
          "group": "1@1"
        },
        {
          "//": "[Container] Import NoSql items",
          "command": "cosmosDB.importDocument",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)|vscode-fabric.view/ && viewItem =~ /treeitem[.]container(?![a-z.\\/])/i && viewItem =~ /experience[.](core|fabric)/i",
          "group": "1@2"
        },
        {
          "//": "[Container] Delete NoSql container",
          "command": "cosmosDB.deleteContainer",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)|vscode-fabric.view/ && viewItem =~ /treeitem[.]container(?![a-z.\\/])/i && viewItem =~ /experience[.](core|fabric)/i",
          "group": "1@3"
        },
        {
          "//": "[Container] View NoSql container offer",
          "command": "cosmosDB.viewContainerOffer",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)/ && viewItem =~ /treeitem[.]container(?![a-z.\\/])/i && viewItem =~ /experience[.](core)/i",
          "group": "1@4"
        },
        {
          "//": "[Container] Refresh",
          "command": "azureDatabases.refresh",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)/ && viewItem =~ /treeitem[.]container(?![a-z.\\/])/i",
          "group": "2@1"
        },
        {
          "//": "[Stored Procedures] Create Stored Procedure",
          "command": "cosmosDB.createStoredProcedure",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)/ && viewItem =~ /treeitem[.]storedProcedures(?![a-z.\\/])/i && viewItem =~ /experience[.](core)/i",
          "group": "1@1"
        },
        {
          "//": "[Stored Procedures] Refresh",
          "command": "azureDatabases.refresh",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)/ && viewItem =~ /treeitem[.]storedProcedures(?![a-z.\\/])/i && viewItem =~ /experience[.](core)/i",
          "group": "2@1"
        },
        {
          "//": "[Stored Procedure] Execute",
          "command": "cosmosDB.executeStoredProcedure",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)/ && viewItem =~ /treeitem[.]storedProcedure(?![a-z.\\/])/i && viewItem =~ /experience[.](core)/i",
          "group": "1@1"
        },
        {
          "//": "[Stored Procedure] Delete",
          "command": "cosmosDB.deleteStoredProcedure",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)/ && viewItem =~ /treeitem[.]storedProcedure(?![a-z.\\/])/i && viewItem =~ /experience[.](core)/i",
          "group": "1@2"
        },
        {
          "//": "[Triggers] Create Trigger",
          "command": "cosmosDB.createTrigger",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)/ && viewItem =~ /treeitem[.]triggers(?![a-z.\\/])/i && viewItem =~ /experience[.](core)/i",
          "group": "1@1"
        },
        {
          "//": "[Triggers] Refresh",
          "command": "azureDatabases.refresh",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)/ && viewItem =~ /treeitem[.]triggers(?![a-z.\\/])/i && viewItem =~ /experience[.](core)/i",
          "group": "2@1"
        },
        {
          "//": "[Trigger] Delete",
          "command": "cosmosDB.deleteTrigger",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)/ && viewItem =~ /treeitem[.]trigger(?![a-z.\\/])/i && viewItem =~ /experience[.](core)/i",
          "group": "1@1"
        },
        {
          "//": "[Documents] Open NoSql query editor",
          "command": "cosmosDB.openNoSqlQueryEditor",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)|vscode-fabric.view/ && viewItem =~ /treeitem[.]items(?![a-z.\\/])/i && viewItem =~ /experience[.](core|fabric)/i",
          "group": "1@1"
        },
        {
          "//": "[Documents] Create NoSql Document",
          "command": "cosmosDB.createDocument",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)|vscode-fabric.view/ && viewItem =~ /treeitem[.]items(?![a-z.\\/])/i && viewItem =~ /experience[.](core|fabric)/i",
          "group": "1@2"
        },
        {
          "//": "[Documents] Refresh",
          "command": "azureDatabases.refresh",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)/ && viewItem =~ /treeitem[.]items(?![a-z.\\/])/i && viewItem =~ /experience[.](core)/i",
          "group": "2@1"
        },
        {
          "//": "[Document] Delete",
          "command": "cosmosDB.deleteDocument",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)|vscode-fabric.view/ && viewItem =~ /treeitem[.]item(?![a-z.\\/])/i && viewItem =~ /experience[.](core|fabric)/i",
          "group": "1@1"
        },
        {
          "//": "[Document] Refresh",
          "command": "azureDatabases.refresh",
          "when": "view =~ /azure(ResourceGroups|Workspace|FocusView)/ && viewItem =~ /treeitem[.]item(?![a-z.\\/])/i && viewItem =~ /experience[.](core)/i",
          "group": "2@1"
        },
        {
          "//": "[Migration] Remove migration",
          "command": "cosmosDB.migration.remove",
          "when": "cosmosDB.migration.enabled && view =~ /azureWorkspace/ && viewItem =~ /treeitem[.]migration(?![a-z.\\/])/i",
          "group": "1@1"
        }
      ],
      "explorer/context": [
        {
          "command": "cosmosDB.importDocument",
          "when": "resourceLangId == json"
        },
        {
          "command": "cosmosDB.migration.openExisting",
          "when": "cosmosDB.migration.enabled && explorerResourceIsFolder && resourceFilename == .cosmosdb-migration",
          "group": "navigation"
        },
        {
          "command": "cosmosDB.migration.openExisting",
          "when": "cosmosDB.migration.enabled && explorerResourceIsFolder && resourceDirname =~ /\\.cosmosdb-migration$/",
          "group": "navigation"
        },
        {
          "command": "cosmosDB.migration.openExisting",
          "when": "cosmosDB.migration.enabled && resourceFilename == project.json && resourceDirname =~ /\\.cosmosdb-migration$/",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "cosmosDB.migration.open",
          "when": "cosmosDB.migration.enabled"
        },
        {
          "command": "azureDatabases.refresh",
          "when": "never"
        },
        {
          "command": "cosmosDB.openUnsupportedAccount",
          "when": "never"
        },
        {
          "command": "azureDatabases.update",
          "when": "never"
        },
        {
          "command": "cosmosDB.migration.openExisting",
          "when": "never"
        },
        {
          "command": "cosmosDB.migration.remove",
          "when": "never"
        },
        {
          "command": "cosmosDB.dev.runNl2QueryQualityTest",
          "when": "cosmosDB.devMode"
        },
        {
          "command": "cosmosDB.e2e.openQueryEditor",
          "when": "cosmosDB.e2eTestMode"
        },
        {
          "command": "cosmosDB.e2e.openDocument",
          "when": "cosmosDB.e2eTestMode"
        },
        {
          "command": "cosmosDB.e2e.attachEmulator",
          "when": "cosmosDB.e2eTestMode"
        },
        {
          "command": "cosmosDB.e2e.setAIFeaturesEnabled",
          "when": "cosmosDB.e2eTestMode"
        },
        {
          "command": "cosmosDB.e2e.setMockLanguageModels",
          "when": "cosmosDB.e2eTestMode"
        },
        {
          "command": "cosmosDB.e2e.clearMockLanguageModels",
          "when": "cosmosDB.e2eTestMode"
        },
        {
          "command": "cosmosDB.e2e.setSurveyCandidate",
          "when": "cosmosDB.e2eTestMode"
        },
        {
          "command": "cosmosDB.e2e.applyEditQuerySuggestion",
          "when": "cosmosDB.e2eTestMode"
        },
        {
          "command": "cosmosDB.e2e.openEditQuerySuggestionSideBySide",
          "when": "cosmosDB.e2eTestMode"
        },
        {
          "command": "cosmosDB.e2e.openMigration",
          "when": "cosmosDB.e2eTestMode"
        },
        {
          "command": "cosmosDB.e2e.openMigrationFresh",
          "when": "cosmosDB.e2eTestMode"
        }
      ]
    },
    "keybindings": [],
    "configuration": [
      {
        "title": "Azure Cosmos DB",
        "properties": {
          "azureDatabases.batchSize": {
            "type": "number",
            "description": "%cosmosdb.configuration.batch.size%",
            "default": 50
          },
          "azureDatabases.useCosmosOAuth": {
            "type": "boolean",
            "markdownDescription": "%cosmosdb.configuration.oauth.enable%",
            "markdownDeprecationMessage": "**Deprecated**: Please use `#azureDatabases.cosmosDB.preferredAuthenticationMethod#` instead.",
            "deprecationMessage": "Deprecated: Please use azureDatabases.cosmosDB.preferredAuthenticationMethod instead."
          },
          "azureDatabases.confirmationStyle": {
            "type": "string",
            "description": "%cosmosdb.configuration.confirmation.style%",
            "enum": [
              "wordConfirmation",
              "challengeConfirmation",
              "buttonConfirmation"
            ],
            "enumItemLabels": [
              "%cosmosdb.configuration.confirmation.style.word%",
              "%cosmosdb.configuration.confirmation.style.challenge%",
              "%cosmosdb.configuration.confirmation.style.button%"
            ],
            "enumDescriptions": [
              "%cosmosdb.configuration.confirmation.style.word.description%",
              "%cosmosdb.configuration.confirmation.style.challenge.description%",
              "%cosmosdb.configuration.confirmation.style.button.description%"
            ],
            "default": "wordConfirmation"
          },
          "azureDatabases.showOperationSummaries": {
            "type": "boolean",
            "default": true,
            "description": "%cosmosdb.configuration.operation.summaries%"
          },
          "cosmosDB.documentLabelFields": {
            "type": "array",
            "default": [
              "name",
              "Name",
              "NAME",
              "ID",
              "UUID",
              "Id",
              "id",
              "_id",
              "uuid"
            ],
            "description": "%cosmosdb.configuration.document.label.fields%"
          },
          "cosmosDB.emulator.port": {
            "type": "integer",
            "default": 8081,
            "description": "%cosmosdb.configuration.emulator.port%"
          },
          "cosmosDB.enableEndpointDiscovery": {
            "type": "boolean",
            "default": true,
            "description": "%cosmosdb.configuration.endpoint.discovery%"
          },
          "cosmosDB.showSavePrompt": {
            "type": "boolean",
            "default": true,
            "description": "%cosmosdb.configuration.save.prompt%"
          },
          "cosmosDB.csvSeparator": {
            "type": "string",
            "default": ";",
            "markdownDescription": "%cosmosdb.configuration.csv.separator%"
          },
          "cosmosDB.shell.path": {
            "type": [
              "string",
              "null"
            ],
            "description": "%cosmosdb.configuration.cosmosDB.shell.path%",
            "default": null
          },
          "cosmosDB.shell.MCP.enabled": {
            "type": "boolean",
            "default": false,
            "description": "%cosmosdb.configuration.cosmosDB.shell.mcp.enabled%"
          },
          "cosmosDB.shell.MCP.port": {
            "type": "integer",
            "default": 6128,
            "description": "%cosmosdb.configuration.cosmosDB.shell.mcp.port%"
          },
          "cosmosDB.queryEditor.generateSchemaBasedOnQueries": {
            "type": "boolean",
            "default": true,
            "description": "%cosmosdb.configuration.queryEditor.generateSchemaBasedOnQueries%"
          },
          "cosmosDB.accountOverview.health.criticalRuPercent": {
            "type": "number",
            "default": 90,
            "minimum": 0,
            "maximum": 100,
            "description": "%cosmosdb.configuration.accountOverview.health.criticalRuPercent%"
          },
          "cosmosDB.accountOverview.health.warningRuPercent": {
            "type": "number",
            "default": 80,
            "minimum": 0,
            "maximum": 100,
            "description": "%cosmosdb.configuration.accountOverview.health.warningRuPercent%"
          },
          "cosmosDB.accountOverview.health.storageGrowthWarningGB": {
            "type": "number",
            "default": 10,
            "minimum": 0,
            "description": "%cosmosdb.configuration.accountOverview.health.storageGrowthWarningGB%"
          },
          "cosmosDB.accountOverview.partition.hotRuSharePercent": {
            "type": "number",
            "default": 40,
            "minimum": 0,
            "maximum": 100,
            "description": "%cosmosdb.configuration.accountOverview.partition.hotRuSharePercent%"
          },
          "cosmosDB.accountOverview.partition.skewedStorageSharePercent": {
            "type": "number",
            "default": 35,
            "minimum": 0,
            "maximum": 100,
            "description": "%cosmosdb.configuration.accountOverview.partition.skewedStorageSharePercent%"
          },
          "cosmosDB.accountOverview.partition.topN": {
            "type": "number",
            "default": 5,
            "minimum": 1,
            "description": "%cosmosdb.configuration.accountOverview.partition.topN%"
          },
          "cosmosDB.accountOverview.advisories.throttlingMinMinutes": {
            "type": "number",
            "default": 30,
            "minimum": 1,
            "description": "%cosmosdb.configuration.accountOverview.advisories.throttlingMinMinutes%"
          },
          "cosmosDB.accountOverview.advisories.overProvisioningPeakPercent": {
            "type": "number",
            "default": 25,
            "minimum": 0,
            "maximum": 100,
            "description": "%cosmosdb.configuration.accountOverview.advisories.overProvisioningPeakPercent%"
          },
          "cosmosDB.accountOverview.advisories.autoscaleCoefficientOfVariation": {
            "type": "number",
            "default": 0.5,
            "minimum": 0,
            "description": "%cosmosdb.configuration.accountOverview.advisories.autoscaleCoefficientOfVariation%"
          },
          "cosmosDB.accountOverview.advisories.indexingUsageRatio": {
            "type": "number",
            "default": 0.3,
            "minimum": 0,
            "description": "%cosmosdb.configuration.accountOverview.advisories.indexingUsageRatio%"
          },
          "cosmosDB.experimental.migration.showTokenEstimate": {
            "type": "boolean",
            "default": false,
            "markdownDescription": "%cosmosdb.configuration.experimental.migration.showTokenEstimate%",
            "tags": [
              "experimental"
            ]
          },
          "cosmosDB.experimental.migration.enabled": {
            "type": "boolean",
            "default": true,
            "markdownDescription": "%cosmosdb.configuration.experimental.migration.enabled%",
            "tags": [
              "experimental"
            ]
          }
        }
      },
      {
        "title": "Authentication",
        "properties": {
          "azureDatabases.cosmosDB.preferredAuthenticationMethod": {
            "type": "string",
            "enum": [
              "auto",
              "accountKey",
              "entraId",
              "managedIdentity"
            ],
            "enumItemLabels": [
              "%cosmosdb.configuration.preferredAuthenticationMethod.auto%",
              "%cosmosdb.configuration.preferredAuthenticationMethod.accountKey%",
              "%cosmosdb.configuration.preferredAuthenticationMethod.entraId%",
              "%cosmosdb.configuration.preferredAuthenticationMethod.managedIdentity%"
            ],
            "markdownEnumDescriptions": [
              "%cosmosdb.configuration.preferredAuthenticationMethod.auto.description%",
              "%cosmosdb.configuration.preferredAuthenticationMethod.accountKey.description%",
              "%cosmosdb.configuration.preferredAuthenticationMethod.entraId.description%",
              "%cosmosdb.configuration.preferredAuthenticationMethod.managedIdentity.description%"
            ],
            "markdownDescription": "%cosmosdb.configuration.preferredAuthenticationMethod%",
            "default": "auto",
            "order": 0
          },
          "azureDatabases.authentication.managedIdentity.clientID": {
            "type": "string",
            "markdownDescription": "%cosmosdb.configuration.authentication.managedIdentity.clientID%",
            "default": null,
            "order": 1
          }
        }
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "cosmosDbShellMcpProvider",
        "label": "Cosmos DB Shell MCP Server Provider"
      }
    ]
  },
  "allowScripts": {
    "@parcel/watcher": false,
    "@vscode/vsce-sign": false,
    "keytar": false
  }
}
